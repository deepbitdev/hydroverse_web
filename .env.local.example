# ── Local development ─────────────────────────────────────────
# Leave NEXT_PUBLIC_SOCKET_URL unset locally.
# server.js runs Next.js + Socket.io on the same port, so the
# client connects to window.location.origin automatically.

# ── Production (Vercel frontend + separate socket server) ─────
# Vercel is serverless and can't run server.js.
# Deploy server.js to Railway / Render / Fly.io, then set:
#
# NEXT_PUBLIC_SOCKET_URL=https://your-socket-server.railway.app
#
# On the socket server, also set:
# ALLOWED_ORIGINS=https://hydroverse-web.vercel.app,https://your-custom-domain.com
# PORT=3001   (or whatever the host assigns)
